<%- include('../partials/shell-top', { title: tenant.name, active: 'tenants', user, flash }) %>

<section class="panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Tenant</p>
      <h2><%= tenant.name %></h2>
      <div class="muted">/<%= tenant.slug %></div>
    </div>
    <%- include('../partials/roleBadge', { role: membership.role }) %>
  </div>
  <div class="grid two">
    <div class="card">
      <h4>Debug</h4>
      <ul class="list">
        <li><a href="/t/<%= tenant.slug %>/_debug/tenant" target="_blank" rel="noreferrer">/t/<%= tenant.slug %>/_debug/tenant</a></li>
        <li><a href="/t/<%= tenant.slug %>/_debug/memberships" target="_blank" rel="noreferrer">/t/<%= tenant.slug %>/_debug/memberships</a></li>
        <% if (membership && (membership.role === 'owner' || membership.role === 'admin')) { %>
        <li><a href="/t/<%= tenant.slug %>/admin">Tenant admin</a></li>
        <% } %>
      </ul>
    </div>
    <div class="card">
      <h4>Your membership</h4>
      <p class="muted">Role: <%- include('../partials/roleBadge', { role: membership.role }) %></p>
      <p class="muted">Wallet: <%= user.wallet_address ? `${user.wallet_address.slice(0,6)}...${user.wallet_address.slice(-4)}` : user.email %></p>
    </div>
  </div>
</section>

<section class="panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Pages</p>
      <h3>Navigate</h3>
    </div>
    <div class="actions">
      <a class="button ghost" href="/t/<%= tenant.slug %>/pages">All pages</a>
    </div>
  </div>
  <div class="grid cards">
    <div class="card">
      <h4>Home</h4>
      <p class="muted">Visibility: public</p>
      <div class="card-actions">
        <a class="button" href="/t/<%= tenant.slug %>/pages/home">Open</a>
      </div>
    </div>
    <div class="card">
      <h4>Member Deck</h4>
      <p class="muted">Visibility: member</p>
      <div class="card-actions">
        <a class="button" href="/t/<%= tenant.slug %>/pages/member-deck">Open</a>
      </div>
    </div>
    <div class="card">
      <h4>Admin</h4>
      <p class="muted">Visibility: role (owner/admin)</p>
      <div class="card-actions">
        <a class="button ghost" href="/t/<%= tenant.slug %>/pages/admin">Open</a>
      </div>
    </div>
  </div>
</section>

<section class="panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Modules</p>
      <h3>Coming soon</h3>
    </div>
  </div>
  <div class="grid cards">
    <div class="card disabled">
      <h4>Tribe Roster</h4>
      <p class="muted">Coming soon.</p>
    </div>
    <div class="card disabled">
      <h4>Alliance</h4>
      <p class="muted">Coming soon.</p>
    </div>
    <div class="card disabled">
      <h4>Activity / Audit</h4>
      <p class="muted">Coming soon.</p>
    </div>
  </div>
</section>

<%- include('../partials/shell-bottom') %>
