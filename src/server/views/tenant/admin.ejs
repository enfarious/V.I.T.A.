<%- include('../partials/shell-top', { title: 'Tenant Admin', active: 'tenants', currentTenant: tenant, user, flash }) %>

<section class="panel">
  <header class="panel-head">
    <div>
      <p class="eyebrow">/<%= tenant.slug %></p>
      <h2>Admin</h2>
      <p class="muted">Manage pages and modules.</p>
    </div>
    <div class="actions">
      <a class="button ghost" href="/t/<%= tenant.slug %>">Dashboard</a>
      <a class="button ghost" href="/t/<%= tenant.slug %>/pages">Pages</a>
    </div>
  </header>
</section>

<section class="panel">
  <h3>Create Page</h3>
  <form method="POST" action="/t/<%= tenant.slug %>/pages">
    <div class="form-grid">
      <label>Title <input name="title" required></label>
      <label>Slug <input name="slug" placeholder="optional"></label>
      <label>Visibility
        <select name="visibility">
          <option value="public">public</option>
          <option value="member">member</option>
          <option value="role">role</option>
          <option value="custom">custom</option>
        </select>
      </label>
      <label>Sort order <input type="number" name="sort_order" value="0"></label>
      <label>Allowed roles (comma) <input name="allowed_roles" placeholder="owner,admin"></label>
    </div>
    <button class="button primary" type="submit">Create Page</button>
  </form>
</section>

<section class="panel">
  <h3>Pages</h3>
  <% if (!pages || pages.length === 0) { %>
    <p class="muted">No pages yet.</p>
  <% } else { %>
    <% pages.forEach(function(p) { %>
      <div class="card">
        <div class="card-header">
          <div>
            <p class="eyebrow"><%= p.slug %></p>
            <h4><%= p.title %></h4>
            <p class="muted">Visibility: <%= p.visibility %></p>
          </div>
          <div class="actions">
            <a class="button ghost" href="/t/<%= tenant.slug %>/pages/<%= p.slug %>">View</a>
          </div>
        </div>
        <form method="POST" action="/t/<%= tenant.slug %>/pages/<%= p.id %>?_method=PATCH">
          <div class="form-grid">
            <label>Title <input name="title" value="<%= p.title %>"></label>
            <label>Slug <input name="slug" value="<%= p.slug %>"></label>
            <label>Visibility
              <select name="visibility" value="<%= p.visibility %>">
                <option value="public" <%= p.visibility === 'public' ? 'selected' : '' %>>public</option>
                <option value="member" <%= p.visibility === 'member' ? 'selected' : '' %>>member</option>
                <option value="role" <%= p.visibility === 'role' ? 'selected' : '' %>>role</option>
                <option value="custom" <%= p.visibility === 'custom' ? 'selected' : '' %>>custom</option>
              </select>
            </label>
            <label>Sort order <input type="number" name="sort_order" value="<%= p.sort_order %>"></label>
            <label>Enabled
              <select name="is_enabled">
                <option value="true" <%= p.is_enabled ? 'selected' : '' %>>true</option>
                <option value="false" <%= !p.is_enabled ? 'selected' : '' %>>false</option>
              </select>
            </label>
          </div>
          <button class="button" type="submit">Save</button>
        </form>

        <div class="modules">
          <h5>Modules</h5>
          <% if (!p.modules || p.modules.length === 0) { %>
            <p class="muted">No modules.</p>
          <% } else { %>
            <% p.modules.forEach(function(m) { %>
              <form class="card" method="POST" action="/t/<%= tenant.slug %>/pages/<%= p.id %>/modules/<%= m.id %>?_method=PATCH">
                <p class="eyebrow"><%= m.type_key %></p>
                <label>Title <input name="title" value="<%= m.title || '' %>"></label>
                <label>Sort order <input type="number" name="sort_order" value="<%= m.sort_order %>"></label>
                <label>Enabled
                  <select name="is_enabled">
                    <option value="true" <%= m.is_enabled ? 'selected' : '' %>>true</option>
                    <option value="false" <%= !m.is_enabled ? 'selected' : '' %>>false</option>
                  </select>
                </label>
                <label>Config (JSON)
                  <textarea name="config_json" rows="3"><%- JSON.stringify(m.config_json || {}, null, 2) %></textarea>
                </label>
                <button class="button ghost" type="submit">Save Module</button>
              </form>
            <% }) %>
          <% } %>
        </div>

        <form class="card" method="POST" action="/t/<%= tenant.slug %>/pages/<%= p.id %>/modules">
          <h5>Add Module</h5>
          <label>Type
            <select name="type_key">
              <option value="tribe_banner">tribe_banner</option>
              <option value="media_carousel">media_carousel</option>
              <option value="activity_feed">activity_feed</option>
              <option value="message_of_cycle">message_of_cycle</option>
              <option value="galaxy_window">galaxy_window</option>
              <option value="roster">roster</option>
            </select>
          </label>
          <label>Title <input name="title"></label>
          <label>Sort order <input type="number" name="sort_order" value="0"></label>
          <label>Config (JSON) <textarea name="config_json" rows="3">{}</textarea></label>
          <button class="button primary" type="submit">Add Module</button>
        </form>
      </div>
    <% }) %>
  <% } %>
</section>

<%- include('../partials/shell-bottom') %>
