<%- include('partials/shell-top', { title: 'Home', active: 'home', user, flash }) %>

<section class="hero">
  <div>
    <p class="eyebrow">VITA Frontier</p>
    <h1>Multi-tenant spine, ready for humans.</h1>
    <p class="muted">Path-based tenants, membership gates, and audits — now with a face so you can see it work.</p>
    <% if (!user) { %>
      <div class="actions">
        <a class="button" href="/auth/register">Create account</a>
        <a class="button ghost" href="/auth/login">Login</a>
      </div>
    <% } %>
  </div>
</section>

<% if (user) { %>
  <section class="panel">
    <div class="panel-head">
      <div>
        <p class="eyebrow">Your tenants</p>
        <h2>Memberships</h2>
      </div>
      <a class="button small" href="/tenants">Manage tenants</a>
    </div>
    <% if (!memberships || memberships.length === 0) { %>
      <p class="muted">You have no tenants yet. Create one to get started.</p>
    <% } else { %>
      <div class="grid cards">
        <% memberships.forEach(m => { %>
          <div class="card">
            <div class="card-head">
              <div>
                <div class="eyebrow">/<%= m.slug %></div>
                <h3><%= m.name %></h3>
              </div>
              <%- include('partials/roleBadge', { role: m.role }) %>
            </div>
            <p class="muted">Tenant ID: <%= m.tenant_id %></p>
            <div class="card-actions">
              <a class="button small" href="/t/<%= m.slug %>">Open</a>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>

<%- include('partials/shell-bottom') %>
